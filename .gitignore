# Ignore Visual Studio temporary files, build results, and
# folders generated by popular Visual Studio add-ons.

# User-specific files
.vscode/
.vs/
*_temp/
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (Mono Auto Generated)
mono_crash.*

# Auto generated files
*.pidb
*.svclog
*.scc

# Backup & report files
*_backup*/
*~.*
*.log
*.report
*.output

# SQL Server files
*.mdf
*.ldf

# Database files
*.db
*.sqlite
*.db-shm
*.db-wal

# Web files
.vscode/

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# npm debug log
npm-debug.log*

# macOS files
.DS_Store

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/

# Ensure node_modules is not ignored, if needed.
!node_modules/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCopReport.xml
.StyleCopCache

